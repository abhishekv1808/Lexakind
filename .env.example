# ─────────────────────────────────────────────────────────────
# Lexakind — environment variables
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for canonical URLs, sitemap, schema)
NEXT_PUBLIC_SITE_URL=https://www.lexakind.com

# Contact details (public)
NEXT_PUBLIC_WHATSAPP=918618888526
NEXT_PUBLIC_PHONE=+918618888526
NEXT_PUBLIC_EMAIL=lexakind1@gmail.com

# ── Lead delivery (Resend) ───────────────────────────────────
# Without these, every form still works but emails NOTHING
# (the API returns { delivered: false }). Add a key + verified
# sender domain to actually receive leads + auto-replies.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
RESEND_FROM=noreply@lexakind.com   # must be on a Resend-verified domain
RESEND_TO=lexakind1@gmail.com      # where leads are delivered

# ── Analytics (GA4) — optional ───────────────────────────────
# If unset, no analytics script loads (zero overhead).
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ── Search Console verification — optional ───────────────────
# Paste only the token (the content="..." value) from Google.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
